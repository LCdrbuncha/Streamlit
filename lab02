#4. miniProject1

import streamlit as st
import pandas as pd

st.title("Meeting Room Booking")
st.header("Welcome")
st.write("Hello")
st.markdown("**ตัวหนา**")

name1 = st.text_input("ชื่อผู้จอง" , key="name1")
room1 = st.selectbox("เลือกห้อง", ["A", "B", "C"])
date = st.date_input("วันที่จอง")

if st.button("บันทึกการจอง"):
    data = pd.DataFrame({
        "ชื่อ": [name1],
        "ห้อง": [room1],
        "วันที่": [date]
    })

    st.success("บันทึกสำเร็จ")
    st.dataframe(data)


#5 Sidebar / menu

menu = st.sidebar.selectbox(
    "Menu",
    ["Home","Booking","Dashboard"]
)

#6 Columns

col1,col2 = st.columns(2)

with col1:
    st.button("Left")

with col2:
    st.button("Right")


#7. Tabs
tab1,tab2 = st.tabs(["Booking","History"])

#8. Container
with st.container():
    st.write("Booking Container")
    tab1,tab2 = st.tabs(["Booking","History"])







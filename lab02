#1. button

import streamlit as st
st.title("My First Web")
st.write("สวัสดี Streamlit")
st.button("Click")

#2. Form

name = st.text_input("ชื่อผู้จอง")
room = st.selectbox("ห้อง", ["A", "B", "C"])
if st.button("บันทึก"):
  st.success(f"จองห้อง {room} โดย {name}")

